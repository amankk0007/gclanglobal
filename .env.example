# Cashfree Payment Gateway Configuration
# Copy this file to .env.local and fill in your actual values

# Cashfree App ID (from your Cashfree dashboard)
VITE_CASHFREE_APP_ID=your_cashfree_app_id_here

# Cashfree App Secret (from your Cashfree dashboard) 
VITE_CASHFREE_APP_SECRET=your_cashfree_app_secret_here

# Environment: 'sandbox' for testing, 'production' for live
VITE_CASHFREE_ENVIRONMENT=sandbox
